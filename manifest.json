{
  "manifest_version": 3,
  "name": "Ness Job Tracker",
  "version": "1.0",
  "description": "Marks submitted jobs on Ness Careers website",
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "content_scripts": [
    {
      "matches": ["https://*.ness-tech.co.il/careers/job/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}